# Claudberghini API Configuration
# URL of the Llama backend the proxy forwards requests to.
CLAUDBERGHINI_API_URL=https://chatjimmy.ai

# ── Real-Anthropic Passthrough (hybrid Opus coordinator) ────────────────────
# When set, requests whose model matches ANTHROPIC_PASSTHROUGH_MATCH are forwarded
# VERBATIM to real Anthropic (no Llama massaging) using this key. This is what lets
# the `claudberghini` launcher run a real-Opus coordinator while sonnet/haiku
# sub-agents route to the proxied Llama backend. Leave blank to disable passthrough
# (everything routes to Llama).
ANTHROPIC_API_KEY=
# Base URL for the real Anthropic Messages API.
ANTHROPIC_API_URL=https://api.anthropic.com
# anthropic-version header sent on passthrough requests (forwarded from the client if present).
ANTHROPIC_VERSION=2023-06-01
# Case-insensitive regex matched against the request model id. Match → real Anthropic;
# no match → proxied Llama. Default routes Opus to Anthropic, everything else to Llama.
ANTHROPIC_PASSTHROUGH_MATCH=opus

# ── Proxy Server ────────────────────────────────────────────────────────────
# Port the proxy listens on.
PROXY_PORT=3000

# ── Logging ─────────────────────────────────────────────────────────────────
# Verbosity level. Options: debug, info, warn, error
LOG_LEVEL=info
# Set to 1 to dump full prompt/response content to logs (WARNING: logs secrets).
DUMP_MESSAGES=0

# ── Backend Selection ────────────────────────────────────────────────────────
# Which LLM backend to use: claudberghini | openrouter
BACKEND=claudberghini

# ── OpenRouter Settings (only used when BACKEND=openrouter) ─────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# Sampling temperature forwarded to OpenRouter.
OPENROUTER_TEMP=0.4

# ── Tool Injection ───────────────────────────────────────────────────────────
# Comma-separated list of allowed tools, or * to disable filtering.
# Default is the coding-focused set used by the launcher.
TOOL_ALLOWLIST=Read,Write,Edit,Bash,Grep,Glob,LS
# How many times to sample when picking a tool call.
TOOL_SAMPLE_ATTEMPTS=5
# How many times to sample when generating a plain (non-tool) answer.
ANSWER_SAMPLE_ATTEMPTS=3
# Set to 1 to skip injecting tool-call format instructions into the system prompt.
DISABLE_TOOL_INJECTION=0

# ── System Prompt Limits ─────────────────────────────────────────────────────
# Maximum system-prompt size in bytes before truncation.
MAX_SYSTEM_BYTES=18000
