#!/bin/zsh
# claudberghini — run Claude Code on Claudberghini's Llama 3.1 8B backend, bare-basic.
#
# Bundles everything we found maximizes the weak model's performance:
#   - routes through the Claudberghini proxy via deep-claude (--endpoint claudberghini)
#   - replaces Claude Code's 120KB system prompt with our compact 2KB Llama prompt
#   - no MCP servers (--strict-mcp-config), no skills (--disable-slash-commands)
#   - no dynamic system-prompt sections
#   - coding-only toolset
# The proxy additionally strips <system-reminder> noise and injects the tool-call format.
#
# Usage:  claudberghini [extra claude args] -p "your task"
#         claudberghini            # interactive
# Run it from the project directory you want to work in (Claude Code sandboxes tools to cwd).

set -e

# Resolve this script's own directory (follow symlinks) so the launcher is portable.
SELF="${(%):-%x}"
while [ -L "$SELF" ]; do SELF="$(readlink "$SELF")"; done
PROXY_DIR="${CLAUDBERGHINI_PROXY_DIR:-$(cd "$(dirname "$SELF")" && pwd)}"
# deep-claude: env override, else on PATH, else the conventional sibling checkout.
DC="${DEEP_CLAUDE_BIN:-$(command -v deep-claude || echo "$PROXY_DIR/../deep-claude/bin/deep-claude")}"
SP="${PROXY_DIR}/llama-system-prompt.txt"
MODEL="${CLAUDBERGHINI_MODEL:-claude-3-5-sonnet-20241022}"
ALLOWED="${CLAUDBERGHINI_TOOLS:-Read,Write,Edit,Bash,Grep,Glob,LS}"

# Ensure the proxy is up
if ! curl -s http://localhost:3000/health >/dev/null 2>&1; then
  echo "[claudberghini] starting proxy..."
  (cd "$PROXY_DIR" && LOG_LEVEL=info node dist/server.js >/tmp/proxy-debug.log 2>&1 &)
  for i in {1..10}; do
    curl -s http://localhost:3000/health >/dev/null 2>&1 && break
    sleep 0.5
  done
fi

exec "$DC" --endpoint claudberghini --model "$MODEL" --allowedTools "$ALLOWED" \
  -- --system-prompt-file "$SP" \
     --exclude-dynamic-system-prompt-sections \
     --strict-mcp-config \
     --disable-slash-commands \
     --setting-sources project \
     "$@"
